{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/cli",
    "apps/themeBuilder",
    "packages/d1",
    "packages/solidDelta",
    "packages/lins",
    "packages/utils",
    "packages/components",
    "packages/schema",
    "apps/testBench",
    "apps/tailwindTest",
    "packages/unoLayout",
    "packages/solidScope"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:wrangler\"",
    "dev:vite": "npm run dev --workspace=@web/theme-builder",
    "dev:wrangler": "wrangler --cwd .output dev",
    "migrate:local": "npm run migrate:local --workspace=@web/theme-builder",
    "migrate:prod": "npm run migrate:prod --workspace=@web/theme-builder",
    "build:schema": "npm run build:schema --workspace=@web/theme-builder",
    "build": "npm run build --workspace=@web/theme-builder",
    "preview": "vinxi build && dev:wrangler",
    "start": "npm run start --workspace=@web/theme-builder",
    "test": "vitest",
    "test:delta": "vitest DeltaMachine"
  },
  "dependencies": {
    "@solidjs/router": "0.15.4",
    "@solidjs/start": "1.3.2",
    "zod": "4.3.6",
    "solid-js": "1.9.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251218.0",
    "concurrently": "^9.2.1",
    "jsdom": "27.2.0",
    "sass-embedded": "1.91.0",
    "tsx": "^4.21.0",
    "vitest": "3.2.4",
    "wrangler": "^4.55.0"
  },
  "engines": {
    "node": ">=22"
  },
  "web-types": {
    "contributions": {
      "types-syntax": "typescript",
      "html": {
        "tags": [
          "x-input"
        ]
      }
    }
  }
}
