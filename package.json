{
  "name": "theme-builder-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:wrangler\"",
    "dev:vite": "npm run dev --workspace=@theme-builder/web",
    "dev:wrangler": "wrangler --cwd .output dev",
    "migrate:local": "npm run migrate:local --workspace=@theme-builder/web",
    "migrate:prod": "npm run migrate:prod --workspace=@theme-builder/web",
    "build:schema": "npm run build:schema --workspace=@theme-builder/web",
    "build": "npm run build --workspace=@theme-builder/web",
    "preview": "vinxi build && dev:wrangler",
    "start": "npm run start --workspace=@theme-builder/web",
    "test": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251218.0",
    "@unocss/preset-attributify": "66.5.12",
    "concurrently": "^9.2.1",
    "jsdom": "27.2.0",
    "sass-embedded": "1.91.0",
    "tsx": "^4.21.0",
    "vitest": "3.2.4",
    "wrangler": "^4.55.0"
  },
  "engines": {
    "node": ">=22"
  },
  "web-types": {
    "contributions": {
      "types-syntax": "typescript",
      "html": {
        "tags": [
          "x-input"
        ]
      }
    }
  }
}
