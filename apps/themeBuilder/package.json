{
  "name": "@web/theme-builder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinxi dev --port 3001",
    "build": "vinxi build",
    "start": "vinxi start",
    "generate:schema": "generate-schema src/models migrations",
    "migrate:local": "npm run generate:schema && wrangler d1 migrations apply DB --local --config ./wrangler.jsonc",
    "migrate:prod": "npm run generate:schema && wrangler d1 migrations apply DB --remote --config ./wrangler.jsonc"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/view": "^6.39.11",
    "solid-js": "2.0.0-beta.4",
    "@solidjs/web": "2.0.0-beta.4",
    "@web/lins": "*",
    "@web/utils": "*",
    "@web/d1": "*",
    "@web/schema": "*",
    "@web/solid-delta": "*",
    "@web/components": "*",
    "@web/unolayout": "*",
    "@web/router": "*",
    "@paralleldrive/cuid2": "3.3.0",
    "unocss": "66.6.0",
    "codemirror": "6.0.2",
    "vinxi": "0.5.11",
    "zod": "4.3.6"
  }
}
