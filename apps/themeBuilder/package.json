    "@solidjs/web": "2.0.0-beta.7",
    "@web/lins": "*",
    "@web/utils": "*",
    "@web/d1": "*",
    "@web/schema": "*",
    "@web/solid-delta": "*",
    "@web/components": "*",
    "@web/unolayout": "*",
    "@web/router": "*",
    "@paralleldrive/cuid2": "3.3.0",
    "tailwindcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "vite-plugin-solid": "3.0.0-next.5",
    "codemirror": "6.0.2",
    "zod": "4.3.6"
  }
