{
  "name": "@web/theme-builder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite dev --port 3001",
    "test": "echo \"Error: no test specified\" && exit 1",
    "check": "tsc --noEmit --project tsconfig.json",
    "generate:schema": "generate-schema src/models migrations",
    "apply:schema": "wrangler d1 migrations apply DB --local --config ./wrangler.jsonc",
    "apply:schema:prod": "wrangler d1 migrations apply DB --remote --config ./wrangler.jsonc",
    "run:projections:local": "run-projections-local src/models --config ./wrangler.jsonc --binding DB",
    "deploy:projections": "wrangler deploy --config ./wrangler.projections.jsonc"
  },
  "dependencies": {
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/view": "6.43.1",
    "@codemirror/state": "6.6.0",
    "@codemirror/autocomplete": "6.20.3",
    "solid-js": "catalog:",
    "@solidjs/web": "catalog:",
    "@web/lins": "workspace:*",
    "@web/utils": "workspace:*",
    "@web/d1": "workspace:*",
    "@web/schema": "workspace:*",
    "@web/solid-delta": "workspace:*",
    "@web/solid-scope": "workspace:*",
    "@web/server-functions": "workspace:*",
    "@web/components": "workspace:*",
    "@web/router": "workspace:*",
    "@paralleldrive/cuid2": "3.3.0",
    "tailwindcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "wrangler": "catalog:",
    "vite-plugin-solid": "catalog:",
    "vite": "catalog:",
    "codemirror": "6.0.2",
    "zod": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20251218.0",
    "tsx": "4.22.4"
  }
}
