{
  "name": "@web/server-functions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "development": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./server": {
      "cloudflare": {
        "types": "./src/cloudflare/server.ts",
        "default": "./src/cloudflare/server.ts"
      },
      "default": {
        "types": "./src/node/server.ts",
        "default": "./src/node/server.ts"
      }
    },
    "./vite": {
      "types": "./src/node/vite-plugin.ts",
      "default": "./src/node/vite-plugin.ts"
    },
    "./runtime": {
      "cloudflare": {
        "types": "./src/cloudflare/runtime/index.ts",
        "default": "./src/cloudflare/runtime/index.ts"
      },
      "default": {
        "types": "./src/node/runtime/index.ts",
        "default": "./src/node/runtime/index.ts"
      }
    }
  },
  "scripts": {"hello": "echo hello",
    "build": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "vite": "^8.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.6.0"
  }
}

